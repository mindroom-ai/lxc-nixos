# Host-local environment for the hosted mindroom.chat runtime.
# Only needed when mindroom.runtime.chat.enable = true (off by default); it
# requires pairing credentials for the hosted mindroom.chat service.
# This file is decrypted to /run/agenix/chat-runtime-env and loaded after the
# shared env bundles, so values here can override shared defaults.
#
# These are already provided by the systemd unit and usually do not belong here:
# MINDROOM_CONFIG_PATH
# MINDROOM_STORAGE_PATH

MATRIX_HOMESERVER=
MATRIX_USERNAME=
MATRIX_PASSWORD=
MATRIX_SSL_VERIFY=
MINDROOM_PROVISIONING_URL=
MINDROOM_LOCAL_CLIENT_ID=
MINDROOM_LOCAL_CLIENT_SECRET=
REDIS_URL=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_VERTEX_PROJECT_ID=
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLOUD_LOCATION=
GOOGLE_CLOUD_PROJECT=
GOOGLE_PROJECT_ID=
GCLOUD_PROJECT=
CLOUD_ML_REGION=
GOOGLE_REDIRECT_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SERPER_API_KEY=
OLLAMA_HOST=
DEEPSEEK_API_KEY=
