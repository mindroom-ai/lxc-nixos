# Host-local environment for the lab runtime (the agents that log in to the
# Tuwunel homeserver running inside this container).
# This file is decrypted to /run/agenix/lab-runtime-env and loaded after the
# shared env bundles, so values here can override shared defaults.
#
# These are already provided by the systemd unit and usually do not belong here:
# MINDROOM_CONFIG_PATH
# MINDROOM_STORAGE_PATH

# The local Tuwunel homeserver. Inside the container this is plain HTTP on
# the loopback interface.
MATRIX_HOMESERVER=http://127.0.0.1:8008

# Must match server_name in hosts/mindroom/constants.nix (siteDomain).
MATRIX_SERVER_NAME=mindroom.lab.mindroom.chat

# Must match the bare token stored in registration-token.age; the runtime
# uses it to register its agent accounts on the local homeserver.
MATRIX_REGISTRATION_TOKEN=

MATRIX_SSL_VERIFY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ENABLE_AI_CACHE=
MINDROOM_ENABLE_STREAMING=
MINDROOM_NAMESPACE=

# Optional override if you do not want the default port:
# BACKEND_PORT=
