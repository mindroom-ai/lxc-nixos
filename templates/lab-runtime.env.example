# Host-local environment for the lab runtime.
# This file is decrypted to /run/agenix/lab-runtime-env and loaded after the
# shared env bundles, so values here can override shared defaults.
#
# These are already provided by the systemd unit and usually do not belong here:
# MINDROOM_CONFIG_PATH
# MINDROOM_STORAGE_PATH

MATRIX_HOMESERVER=
MATRIX_SERVER_NAME=
MATRIX_REGISTRATION_TOKEN=
MATRIX_SSL_VERIFY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ENABLE_AI_CACHE=
MINDROOM_ENABLE_STREAMING=
MINDROOM_NAMESPACE=

# Optional override if you do not want the default port:
# BACKEND_PORT=
